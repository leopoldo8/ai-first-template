{
  "$schema": "https://json-schema.org/schema",
  "id": "package",
  "title": "Package Generator",
  "description": "Creates a new shared package",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the package (e.g., shared-auth, shared-logging)",
      "x-prompt": "What is the name of the package?"
    },
    "tags": {
      "type": "string",
      "description": "Comma-separated NX tags (e.g., scope:shared,type:utils)",
      "default": "scope:shared"
    }
  },
  "required": ["name"]
}
